# Joplin Note Node — configuration
# Copy this file to /etc/joplin-note-node/env and fill in your values.
# Lines starting with # are comments and are ignored.

# Backend: "webclipper" (requires Joplin Desktop) or "server" (standalone)
#JOPLIN_BACKEND=webclipper

# ── Web Clipper backend ───────────────────────────────────────────────────────
# Token shown in Joplin → Tools → Options → Web Clipper
#JOPLIN_TOKEN=your_token_here
# URL of the Web Clipper HTTP server (default shown)
#JOPLIN_CLIPPER_URL=http://localhost:41184

# ── Joplin Server backend ─────────────────────────────────────────────────────
#JOPLIN_SERVER_URL=http://localhost:22300
#JOPLIN_EMAIL=admin@example.com
#JOPLIN_PASSWORD=your_password_here

# ── Node network settings ─────────────────────────────────────────────────────
# Port this NWP node listens on (default 17480)
#JOPLIN_PORT=17480
# Public base URL announced in graph.refs (defaults to http://localhost:<port>)
#JOPLIN_NODE_URL=http://my-server.local:17480
